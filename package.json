{
  "name": "coder-onboarding-tool",
  "private": true,
  "workspaces": [
    "apps/server",
    "apps/web"
  ],
  "scripts": {
    "dev": "bun --filter @coder-onboarding/server dev",
    "dev:web": "bun --filter @coder-onboarding/web dev",
    "dev:all": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test",
    "db:generate": "bun --filter @coder-onboarding/server db:generate",
    "db:migrate": "bun --filter @coder-onboarding/server db:migrate"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.3"
  }
}
